# Production Environment Configuration

# Database Configuration
DATABASE_URL="postgresql://user:password@production-db-host:5432/crm_db?schema=public&charset=utf8"

# JWT Secret - MUST BE CHANGED! Generate a strong random string
JWT_SECRET="your-very-strong-random-secret-key-at-least-32-chars-long"

# Server Port
PORT=5000

# CORS Configuration - Your production domain
CORS_ORIGIN="https://your-domain.com"

# Environment
NODE_ENV="production"

# Log Level
LOG_LEVEL="warn"
